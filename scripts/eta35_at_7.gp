x='x;K=bnfinit(x^2-x-1,1);
P3=idealprimedec(K,3)[1];P5=idealprimedec(K,5)[1];
m=idealmul(K,idealpow(K,P3,3),idealpow(K,P5,3));
B=bnrinit(K,[m,[1,1]],1);
P7=idealprimedec(K,7)[1];
c=Vec(bnrisprincipal(B,P7,0));
print("P7=",P7);
print("raycoord(P7)=",c);
forchar=[[0,0],[0,1],[90,0],[90,1]];
for(i=1,#forchar,my(ch=forchar[i]);my(e=(c[1]*ch[1])%180);my(s=(c[2]*ch[2])%2);print(ch," exponents=",[e,s]," quadratic_value=",if((e==0)&&(s==0),1,if((e==90)||(s==1),-1,"nonquadratic"))));
quit;